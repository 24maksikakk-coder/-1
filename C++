// 05-cpp/calculator.cpp
#include <iostream>
#include <string>
using namespace std;

int main() {
    cout << "=== C++ Calculator ===" << endl;
    double a, b;
    char op;
    cout << "First number: ";
    cin >> a;
    cout << "Operator (+, -, *, /): ";
    cin >> op;
    cout << "Second number: ";
    cin >> b;
    double result;
    switch (op) {
        case '+': result = a + b; break;
        case '-': result = a - b; break;
        case '*': result = a * b; break;
        case '/':
            if (b == 0) {
                cout << "Error: division by zero" << endl;
                return 1;
            }
            result = a / b;
            break;
        default:
            cout << "Error: invalid operator" << endl;
            return 1;
    }
    cout << "Result: " << result << endl;
    return 0;
}
